{% extends "base.html.j2" %}

{% block title %}Staff login — Southern Cross Financial{% endblock %}

{% block content %}
<section class="section-pad text-center">
    <div class="wrap-narrow">
        <p class="eyebrow">Staff portal</p>
        <h1 style="margin-bottom: var(--sc-px-5); font-style: italic;">Sign in.</h1>
        <p class="lead" style="margin: 0 auto var(--sc-px-6);">Southern Cross staff and advisers only. Enter your work email and we will send you a 6-digit access code.</p>

        <form id="login-form" style="max-width: 480px; margin: 0 auto; display: grid; gap: var(--sc-px-3); border: 1px solid var(--sc-line); padding: var(--sc-px-5); background: var(--sc-bg); position: relative;">
            <div style="position: absolute; inset: 6px; border: 1px solid var(--sc-line); pointer-events: none;"></div>
            <label class="label" for="email" style="text-align: left;">Work email</label>
            <input type="email" id="email" name="email" required placeholder="firstname.lastname@southerncrossfinancial.com.au" style="padding: var(--sc-px-3); background: var(--sc-bg-2); border: 1px solid var(--sc-line-2); color: var(--sc-text); font-family: var(--sc-font-body);">
            <button type="submit" class="btn btn-primary btn-arrow">Send access code</button>
            <p class="label" style="margin-top: var(--sc-px-2); text-align: left; color: var(--sc-text-dim);">Authentication coming soon — placeholder for the WorkReady simulation.</p>
        </form>
    </div>
</section>
{% endblock %}
