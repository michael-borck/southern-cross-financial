<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Southern Cross Financial — Wealth Management & Advisory{% endblock %}</title>
    <meta name="description" content="{% block description %}Boutique Western Australian wealth management, financial planning, and corporate advisory firm. AFSL holder serving high-net-worth clients since 2011.{% endblock %}">
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="stylesheet" href="/styles/main.css">
    {% block head_extra %}{% endblock %}
</head>
<body>
    <div class="masthead-bar">
        <em>A boutique Western Australian wealth firm</em> &nbsp;<span>·</span>&nbsp; <em>Established 2011</em> &nbsp;<span>·</span>&nbsp; <em>AFSL holder</em>
    </div>

    <header class="header">
        <div class="header-inner">
            <a href="/" class="brand">
                <div class="brand-logo">SC</div>
                <div class="brand-name">
                    <strong>Southern Cross</strong>
                    <span>Financial / Perth WA</span>
                </div>
            </a>
            <nav class="nav">
                <a href="/" class="{% if page == 'index' %}active{% endif %}">Home</a>
                <a href="/about.html" class="{% if page == 'about' %}active{% endif %}">About</a>
                <a href="/services.html" class="{% if page == 'services' %}active{% endif %}">Services</a>
                <a href="/careers.html" class="{% if page == 'careers' %}active{% endif %}">Careers</a>
                <a href="/contact.html" class="{% if page == 'contact' %}active{% endif %}">Contact</a>
                <a href="/contact.html" class="nav-cta">Arrange a meeting</a>
            </nav>
        </div>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="wrap">
            <div class="footer-grid">
                <div class="footer-brand">
                    <h3>Southern Cross Financial</h3>
                    <p>A boutique Western Australian wealth management and advisory firm. Personal advice for individuals, families, and business owners since 2011.</p>
                    <div style="margin-top: var(--sc-px-3);">
                        <span class="afsl-badge">AFSL 000000</span>
                    </div>
                </div>
                <div class="footer-col">
                    <h4>Firm</h4>
                    <ul>
                        <li><a href="/about.html">About</a></li>
                        <li><a href="/services.html">Services</a></li>
                        <li><a href="/careers.html">Careers</a></li>
                        <li><a href="/contact.html">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>For Staff</h4>
                    <ul>
                        <li><a href="/staff/">Staff portal</a></li>
                        <li><a href="/staff/directory.html">Directory</a></li>
                        <li><a href="/staff/documents.html">Documents</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Disclosures</h4>
                    <ul>
                        <li><a href="#">Financial Services Guide</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Complaints</a></li>
                        <li><a href="#">ASIC register</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; {{ year }} Southern Cross Financial Pty Ltd / ABN 00 000 000 000 / AFSL 000000</p>
                <p class="footer-disclaimer">A fictional firm, made for a Curtin University internship simulation. Not a real AFSL holder.</p>
            </div>
        </div>
    </footer>
</body>
</html>
